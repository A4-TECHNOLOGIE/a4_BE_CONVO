})\n","README.md":"","custom.ts":"enum ButtonChoice {\n    C,\n    D\n}\n\n//% weight=100 color=#ff69b4 icon=\"\\u26a1\" \n//% groups=\"['Boutons Poussoirs', 'Potentiomètre', 'Moteur', 'Servomoteurs', 'Ecran OLED', 'Anneau lumineux']\"\nnamespace convoyeur {\n\n    //%block=\"Lorsque bouton %button est appuyé\"\n    //%group='Boutons Poussoirs'\n    export function onButtonPressed(button: ButtonChoice, handler: () => void){\n    }\n\n    //%block=\"Bouton %button appuyé\" \n    export function buttonPressed(button: ButtonChoice){\n        if (button==ButtonChoice.C){\n            let button = pins.digitalReadPin(DigitalPin.P13)\n        }\n        else if (button==ButtonChoice.D){\n            let button = pins.digitalReadPin(DigitalPin.P14)\n        }\n        return true;\n    }\n}","pxt.json":"{\n    \"name\": \"Sans titre\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"custom.ts\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1775201103586,"editorVersion":"8.0.21","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"device_forever\" x=\"0\" y=\"0\"><statement name=\"HANDLER\"><block type=\"fans\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" _expanded=\"1\" _input_init=\"true\"></mutation><field name=\"Rjpin\">PlanetX_Basic.DigitalRJPin.J1</field><value name=\"fanstate\"><shadow type=\"toggleOnOff\"><field name=\"on\">false</field></shadow></value><value name=\"speed\"><shadow type=\"math_number_minmax\"><mutation min=\"0\" max=\"100\" label=\"Speed\" precision=\"0\"></mutation><field name=\"SLIDER\">50</field></shadow></value></block></statement></block></xml>","main.ts":"basic.forever(function () {\n    PlanetX_Basic.motorFan(PlanetX_Basic.DigitalRJPin.J1, false, 50)\n})\n","README.md":"","custom.ts":"enum ButtonChoice {\n    C,\n    D\n}\n\n//% weight=100 color=#ff69b4 icon=\"\\u26a1\" \n//% groups=\"['Boutons Poussoirs', 'Potentiomètre', 'Moteur', 'Servomoteurs', 'Ecran OLED', 'Anneau lumineux']\"\nnamespace convoyeur {\n\n    //%block=\"Lorsque bouton %button est appuyé\"\n    //%group='Boutons Poussoirs'\n    export function onButtonPressed(button: ButtonChoice, handler: () => void){\n    }\n\n    //%block=\"Bouton %button appuyé\" \n    //%group='Boutons Poussoirs'\n    export function buttonPressed(button: ButtonChoice){\n        if (button==ButtonChoice.C){\n            let button = pins.digitalReadPin(DigitalPin.P13)\n        }\n        else if (button==ButtonChoice.D){\n            let button = pins.digitalReadPin(DigitalPin.P14)\n        }\n        return true;\n    }\n\n    export function buttonPressed(button: ButtonChoice): boolean {\n        if (button == ButtonChoice.C) {\n            return pins.digitalReadPin(DigitalPin.P13) == 0; // Retourne true si pressé\n        } else {\n            return pins.digitalReadPin(DigitalPin.P14) == 0;\n        }\n    }\n\n    //%block=\"Valeur potentiomètre\"\n    //%group='Potentiomètre'\n    export function potentiometerValue(){\n        return pins.analogReadPin(AnalogPin.P2)\n    }\n\n    //%block=\"Moteur activé à la vitesse %speed\"\n    //%group='Moteur'\n    //% speed.min=0 speed.max=100 speed.defl=50 \n    export function setMotorSpeed(speed: number){\n        let safeSpeed = Math.max(0, Math.min(100, speed));\n        let pwmValue = Math.map(safeSpeed, 0, 100, 0, 1023);\n        pins.digitalWritePin(DigitalPin.P16, 0);\n        pins.analogWritePin(AnalogPin.P15, pwmValue);\n    }\n}","pxt.json":"{\n    \"name\": \"Sans titre\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"pxt-PlanetX\": \"github:elecfreaks/pxt-planetx#v1.6.2\"\n    },\n    \"files\": [\n        \"main.blocks\"