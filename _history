pins.digitalWritePin(DigitalPin.P15, 0)\n        pins.digitalWritePin(DigitalPin.P16, 0)\n    }\n\n    //%block=\"Activer le moteur\"\n    //%group='Moteur' \n    export function startMotor() {\n        pins.digitalWritePin(DigitalPin.P15, 1)\n        pins.digitalWritePin(DigitalPin.P16, 0)\n    } \n\n    //%block=\"Fixe l'angle du servo à %angle °\"\n    //%group='Servomoteur\" \n    export function servoAngle(angle: number){\n        \n    }\n\n    //%block=\"Set servo angle to %angle °\"\n    export function setServoAngel(angle: number): void {\n        let iic_buffer = pins.createBuffer(4);\n        iic_buffer[1] = angle;\n        iic_buffer[2] = 0;\n        iic_buffer[3] = 0;\n    }\n\n}","pxt.json":"{\n    \"name\": \"Sans titre\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"pxt-PlanetX\": \"github:elecfreaks/pxt-planetx#v1.6.2\",\n        \"pxt-nezha\": \"github:elecfreaks/pxt-nezha#v1.3.10\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"custom.ts\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1775205311178,"editorVersion":"8.0.21","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"device_forever\" x=\"0\" y=\"0\"></block></xml>","main.ts":"","README.md":"","custom.ts":"enum ButtonChoice {\n    C,\n    D\n}\n\n//% weight=100 color=#EB8AEB icon=\"\\u26a1\"\n//% groups=\"['Boutons Poussoirs', 'Potentiomètre', 'Moteur', 'Servomoteur', 'Ecran OLED', 'Anneau lumineux']\"\nnamespace convoyeur {\n\n    //%block=\"Lorsque bouton %button est appuyé\"\n    //%group='Boutons Poussoirs'\n    export function onButtonPressed(button: ButtonChoice, handler: () => void){\n    }\n\n    //%block=\"Bouton %button appuyé\" \n    //%group='Boutons Poussoirs'\n    export function buttonPressed(button: ButtonChoice): boolean {\n     